{
  "expo": {
    "name": "PhysTech",
    "slug": "fiztex",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fiztex",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#2A8847",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "kz.fiztex.app"
    },
    "android": {
      "package": "kz.fiztex.app",
      "adaptiveIcon": {
        "backgroundColor": "#2A8847"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "Камера нужна для фото-ответов на вступительном тесте."
        }
      ]
    ],
    "web": {
      "bundler": "metro"
    }
  }
}
